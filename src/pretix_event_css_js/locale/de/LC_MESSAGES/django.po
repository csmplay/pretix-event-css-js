#: src/pretix_event_css_js/apps.py:16 src/pretix_event_css_js/signals.py:20
#: src/pretix_event_css_js/templates/pretix_event_css_js/control_settings.html:5
#: src/pretix_event_css_js/templates/pretix_event_css_js/control_settings.html:9
msgid "Event CSS & JS"
msgstr "Event-CSS & JS"

#: src/pretix_event_css_js/apps.py:18
msgid ""
"Inject custom CSS and JavaScript into the presale pages of individual events."
msgstr ""
"Eigenes CSS und JavaScript in die Vorverkaufsseiten einzelner Events "
"einfügen."

#: src/pretix_event_css_js/forms.py:9
msgid "Custom CSS"
msgstr "Eigenes CSS"

#: src/pretix_event_css_js/forms.py:11
msgid ""
"Custom CSS rules that will be loaded on every presale page of this event."
msgstr ""
"Eigene CSS-Regeln, die auf jeder Vorverkaufsseite dieses Events geladen "
"werden."

#: src/pretix_event_css_js/forms.py:15
msgid "Custom JavaScript"
msgstr "Eigenes JavaScript"

#: src/pretix_event_css_js/forms.py:18
msgid ""
"Custom JavaScript that will be loaded at the end of every presale page of "
"this event. Use with care — incorrect code may break the shop experience for "
"your customers."
msgstr ""
"Eigenes JavaScript, das am Ende jeder Vorverkaufsseite dieses Events geladen "
"wird. Bitte mit Vorsicht verwenden — fehlerhafter Code kann das "
"Einkaufserlebnis Ihrer Kunden beeinträchtigen."

#: src/pretix_event_css_js/templates/pretix_event_css_js/control_settings.html:17
msgid "Save"
msgstr "Speichern"
